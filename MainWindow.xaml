<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="USBShare.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:USBShare.Models"
    xmlns:viewModels="using:USBShare.ViewModels"
    xmlns:local="using:USBShare"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="USBShare">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" RowDefinitions="Auto,*,Auto" Padding="12" RowSpacing="12">
        <CommandBar DefaultLabelPosition="Collapsed" VerticalAlignment="Top">
            <AppBarButton Label="刷新" Icon="Refresh" Click="RefreshButton_Click" />
            <AppBarSeparator />
            <AppBarButton x:Name="StartShareButton" Label="开始分享" Icon="Play" Click="StartShareButton_Click" />
            <AppBarButton x:Name="StopShareButton" Label="停止分享" Icon="Stop" Click="StopShareButton_Click" IsEnabled="False" />
            <AppBarSeparator />
            <AppBarButton Label="管理员重启" Icon="Admin" Click="RestartAsAdminButton_Click" />
        </CommandBar>

        <Grid Grid.Row="1" ColumnDefinitions="360,*" ColumnSpacing="12">
            <Border Grid.Column="0"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Padding="12">
                <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto" RowSpacing="8">
                    <TextBlock Text="SSH 远程配置" FontSize="18" FontWeight="SemiBold" />

                    <!-- 当前分享目标显示 -->
                    <Border Grid.Row="1"
                            CornerRadius="4"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            Padding="8"
                            Margin="0,4,0,0">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <FontIcon Glyph="&#xE890;" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="当前分享目标" FontSize="12" Opacity="0.72" />
                                <TextBlock x:Name="CurrentTargetTextBlock"
                                           Text="未选择"
                                           FontWeight="SemiBold"
                                           Opacity="0.9" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ListView x:Name="RemoteListView"
                              Grid.Row="2"
                              SelectionMode="Single"
                              SelectionChanged="RemoteListView_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:RemoteConfig">
                                <StackPanel Spacing="2" Padding="4">
                                    <TextBlock Text="{x:Bind DisplayTitle}" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind DisplaySubtitle}" FontSize="12" Opacity="0.72" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                        <Button Content="新增" Click="AddRemoteButton_Click" />
                        <Button Content="编辑" Click="EditRemoteButton_Click" />
                        <Button Content="删除" Click="DeleteRemoteButton_Click" />
                        <Button Content="测试连接" Click="TestRemoteButton_Click" />
                    </StackPanel>

                    <Button x:Name="SetAsTargetButton"
                            Grid.Row="4"
                            Content="设为分享目标"
                            Click="SetAsTargetButton_Click"
                            IsEnabled="False" />

                    <StackPanel Grid.Row="5" Spacing="6">
                        <TextBlock Text="轮询间隔(秒)" />
                        <NumberBox x:Name="PollIntervalNumberBox"
                                   Minimum="1"
                                   Maximum="30"
                                   SmallChange="1"
                                   SpinButtonPlacementMode="Inline"
                                   ValueChanged="PollIntervalNumberBox_ValueChanged" />
                        <TextBlock x:Name="AdminHintTextBlock"
                                   TextWrapping="Wrap"
                                   Opacity="0.8" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto" RowSpacing="8">
                <TextBlock Text="USB 设备分享" FontSize="18" FontWeight="SemiBold" />

                <Border Grid.Row="1"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <TreeView x:Name="UsbTreeView"
                              Padding="8"
                              SelectionMode="Single"
                              SelectionChanged="UsbTreeView_SelectionChanged">
                        <TreeView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Padding="6"
                                      Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                      CornerRadius="4">
                                    <!-- 设备图标 -->
                                    <FontIcon Glyph="{Binding Content.Glyph}"
                                              VerticalAlignment="Center" />

                                    <!-- 设备信息 -->
                                    <StackPanel Grid.Column="1" Spacing="2">
                                        <TextBlock Text="{Binding Content.Title}"
                                                   FontWeight="SemiBold"
                                                   Opacity="{Binding Content.TitleOpacity}" />
                                        <TextBlock Text="{Binding Content.Subtitle}"
                                                   FontSize="11"
                                                   Opacity="0.7" />

                                        <!-- 状态徽章（仅在有非默认状态时显示） -->
                                        <Border Background="{Binding Content.StatusBadgeBrush, Mode=OneWay}"
                                                Padding="4,2"
                                                CornerRadius="2"
                                                HorizontalAlignment="Left"
                                                Visibility="{Binding Content.ShowStatusBadge, Mode=OneWay}">
                                            <TextBlock Text="{Binding Content.StatusText, Mode=OneWay}"
                                                       FontSize="10"
                                                       Foreground="White" />
                                        </Border>
                                    </StackPanel>

                                    <!-- 内联交互区域 -->
                                    <Grid Grid.Column="2">
                                        <!-- 状态图标（不可交互或继承状态时显示） -->
                                        <FontIcon Glyph="{Binding Content.StatusIcon, Mode=OneWay}"
                                                  Foreground="{Binding Content.StatusBrushNew, Mode=OneWay}"
                                                  FontSize="16"
                                                  VerticalAlignment="Center"
                                                  Visibility="{Binding Content.HasStatusIcon, Mode=OneWay}" />

                                        <!-- 直接交互的 CheckBox (仅当可交互时显示) -->
                                        <CheckBox IsChecked="{Binding Content.IsEnabled, Mode=TwoWay}"
                                                  Click="DeviceCheckBox_Click"
                                                  Tag="{Binding Content.InstanceId, Mode=OneWay}"
                                                  MinWidth="0"
                                                  Visibility="{Binding Content.ShowCheckBox, Mode=OneWay}" />
                                    </Grid>
                                </Grid>
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>

                <InfoBar x:Name="StatusInfoBar"
                         Grid.Row="2"
                         IsOpen="False"
                         IsClosable="False"
                         Severity="Informational"
                         Message="Ready" />
            </Grid>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="提示: 所有启用的设备将统一分享到左侧选中的远程服务器。"
                   Opacity="0.72" />
    </Grid>
</Window>

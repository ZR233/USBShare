<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="USBShare.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:USBShare.Models"
    xmlns:viewModels="using:USBShare.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="USBShare">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid x:Name="RootGrid" RowDefinitions="Auto,*,Auto" Padding="12" RowSpacing="12">
        <CommandBar DefaultLabelPosition="Collapsed" VerticalAlignment="Top">
            <AppBarButton Label="刷新" Icon="Refresh" Click="RefreshButton_Click" />
            <AppBarSeparator />
            <AppBarButton x:Name="StartShareButton" Label="开始分享" Icon="Play" Click="StartShareButton_Click" />
            <AppBarButton x:Name="StopShareButton" Label="停止分享" Icon="Stop" Click="StopShareButton_Click" IsEnabled="False" />
            <AppBarSeparator />
            <AppBarButton Label="管理员重启" Icon="Admin" Click="RestartAsAdminButton_Click" />
        </CommandBar>

        <Grid Grid.Row="1" ColumnDefinitions="360,*" ColumnSpacing="12">
            <Border Grid.Column="0"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    Padding="12">
                <Grid RowDefinitions="Auto,Auto,*,Auto,Auto,Auto" RowSpacing="8">
                    <TextBlock Text="SSH 远程配置" FontSize="18" FontWeight="SemiBold" />

                    <!-- 当前分享目标显示 -->
                    <Border Grid.Row="1"
                            CornerRadius="4"
                            Background="{ThemeResource LayerFillColorDefaultBrush}"
                            Padding="8"
                            Margin="0,4,0,0">
                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                            <FontIcon Glyph="&#xE890;" VerticalAlignment="Center" />
                            <StackPanel Grid.Column="1" Spacing="2">
                                <TextBlock Text="当前分享目标" FontSize="12" Opacity="0.72" />
                                <TextBlock x:Name="CurrentTargetTextBlock"
                                           Text="未选择"
                                           FontWeight="SemiBold"
                                           Opacity="0.9" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <ListView x:Name="RemoteListView"
                              Grid.Row="2"
                              SelectionMode="Single"
                              SelectionChanged="RemoteListView_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:RemoteConfig">
                                <StackPanel Spacing="2" Padding="4">
                                    <TextBlock Text="{x:Bind DisplayTitle}" FontWeight="SemiBold" />
                                    <TextBlock Text="{x:Bind DisplaySubtitle}" FontSize="12" Opacity="0.72" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <StackPanel Grid.Row="3" Orientation="Horizontal" Spacing="8">
                        <Button Content="新增" Click="AddRemoteButton_Click" />
                        <Button Content="编辑" Click="EditRemoteButton_Click" />
                        <Button Content="删除" Click="DeleteRemoteButton_Click" />
                        <Button Content="测试连接" Click="TestRemoteButton_Click" />
                    </StackPanel>

                    <Button x:Name="SetAsTargetButton"
                            Grid.Row="4"
                            Content="设为分享目标"
                            Click="SetAsTargetButton_Click"
                            IsEnabled="False" />

                    <StackPanel Grid.Row="5" Spacing="6">
                        <TextBlock Text="轮询间隔(秒)" />
                        <NumberBox x:Name="PollIntervalNumberBox"
                                   Minimum="1"
                                   Maximum="30"
                                   SmallChange="1"
                                   SpinButtonPlacementMode="Inline"
                                   ValueChanged="PollIntervalNumberBox_ValueChanged" />
                        <TextBlock x:Name="AdminHintTextBlock"
                                   TextWrapping="Wrap"
                                   Opacity="0.8" />
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Column="1" RowDefinitions="Auto,*,Auto,Auto" RowSpacing="8">
                <TextBlock Text="USB 设备分享" FontSize="18" FontWeight="SemiBold" />

                <Border Grid.Row="1"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                    <TreeView x:Name="UsbTreeView"
                              Padding="8"
                              SelectionMode="Single"
                              SelectionChanged="UsbTreeView_SelectionChanged">
                        <TreeView.ItemTemplate>
                            <DataTemplate>
                                <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8" Padding="4">
                                    <FontIcon Glyph="{Binding Content.Glyph}" VerticalAlignment="Top" />
                                    <StackPanel Grid.Column="1" Spacing="1">
                                        <TextBlock Text="{Binding Content.Title}" Opacity="{Binding Content.TitleOpacity}" />
                                        <TextBlock Text="{Binding Content.Subtitle}" FontSize="12" Opacity="0.72" TextWrapping="WrapWholeWords" />
                                    </StackPanel>
                                    <!-- 启用状态图标 -->
                                    <FontIcon Grid.Column="2"
                                              Glyph="{Binding Content.StatusGlyph}"
                                              Foreground="{Binding Content.StatusBrush, Mode=OneWay}"
                                              FontSize="14"
                                              VerticalAlignment="Center"
                                              Visibility="{Binding Content.HasStatus, Mode=OneWay}" />
                                </Grid>
                            </DataTemplate>
                        </TreeView.ItemTemplate>
                    </TreeView>
                </Border>

                <Border Grid.Row="2"
                        CornerRadius="8"
                        BorderThickness="1"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                        Padding="12">
                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="8">
                        <TextBlock x:Name="SelectedNodeTextBlock" Text="选中节点: (无)" />
                        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8">
                            <CheckBox x:Name="EnableDeviceCheckBox"
                                      Content="启用分享"
                                      Checked="EnableDeviceCheckBox_CheckedChanged"
                                      Unchecked="EnableDeviceCheckBox_CheckedChanged"
                                      IsEnabled="False" />
                        </StackPanel>
                        <TextBlock Grid.Row="2"
                                   Text="提示: 勾选 Hub 后，其下的所有可分享设备将自动继承启用状态。灰色设备不可直接分享。"
                                   Opacity="0.78"
                                   TextWrapping="WrapWholeWords" />
                    </Grid>
                </Border>

                <InfoBar x:Name="StatusInfoBar"
                         Grid.Row="3"
                         IsOpen="False"
                         IsClosable="False"
                         Severity="Informational"
                         Message="Ready" />
            </Grid>
        </Grid>

        <TextBlock Grid.Row="2"
                   Text="提示: 所有启用的设备将统一分享到左侧选中的远程服务器。"
                   Opacity="0.72" />
    </Grid>
</Window>
